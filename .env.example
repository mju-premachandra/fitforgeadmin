VITE_API_URL=http://localhost:3000

# --- Vercel Blob (photos + videos) ---
# 1. Vercel dashboard → Storage → Create Blob store (e.g. fitforge-admin)
# 2. Open the store → .env.local tab → copy BLOB_READ_WRITE_TOKEN
# 3. Paste into fitforgeadmin/.env.local (do NOT commit this file)
#
# Or from this folder:
#   npx vercel link
#   npx vercel env pull .env.local
#
# Local dev reads .env.local first, then .env
BLOB_READ_WRITE_TOKEN=""

# Optional: server-side API URL for upload auth checks (defaults to VITE_API_URL)
# API_URL=http://localhost:3000

# Optional: point local dev at a deployed upload route instead of Vite middleware
# VITE_BLOB_UPLOAD_URL=https://your-admin.vercel.app/api/media/upload
