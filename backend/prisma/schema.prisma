generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

enum AdminRole {
  OWNER
  ADMIN
  TRAINER
}

model Admin {
  id           String    @id @default(cuid())
  name         String
  email        String    @unique
  passwordHash String
  role         AdminRole @default(ADMIN)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
}

model Exercise {
  id               String   @id @default(cuid())
  name             String
  instructions     String
  frontMuscleImage String
  backMuscleImage  String
  video            String
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}
